# ---- LLM provider for chat/generation: openai | deepseek ----
LLM_PROVIDER=openai

# ---- OpenAI (chat if LLM_PROVIDER=openai; ALWAYS required for embeddings) ----
OPENAI_API_KEY=sk-...

# ---- DeepSeek (required only if LLM_PROVIDER=deepseek; OpenAI-compatible API) ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- Recommended (reranking; pipeline works without it, just lower precision) ----
COHERE_API_KEY=

# ---- Models (override to whatever you run in 2026) ----
EMBED_MODEL=text-embedding-3-large
EMBED_DIM=3072
# Chat models. Leave commented to use sensible per-provider defaults
# (openai: gpt-4o / gpt-4o-mini, deepseek: deepseek-chat / deepseek-chat).
# CHAT_MODEL=gpt-4o
# SMALL_MODEL=gpt-4o-mini
RERANK_MODEL=rerank-v3.5

# ---- Data / storage ----
MD_DIR=out_md
QDRANT_PATH=./qdrant_data
# QDRANT_URL=http://localhost:6333   # local: `docker compose up qdrant`. prod: your managed Qdrant URL
# QDRANT_API_KEY=                     # auth token for a managed/remote Qdrant (leave blank for local)
QDRANT_COLLECTION=got_wiki
BM25_PATH=./bm25_index.pkl

# ---- Retrieval tuning ----
DENSE_TOP_K=30
SPARSE_TOP_K=30
RERANK_TOP_N=6
MAX_AGENT_LOOPS=2
